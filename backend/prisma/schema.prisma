generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum PageType {
  BLANK
  TEXT
  BOARD
  DATABASE
  TASKS
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String
  role               String              @default("usuario")
  passwordHash       String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        WorkspaceMember[]
  tasksCreated       Task[]              @relation("TaskCreatedBy")
  tasksAssigned      Task[]              @relation("TaskAssignedTo")
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  color     String            @default("#6472EB")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  spaces    Space[]
  pages     Page[]
  tasks     Task[]
  settings  TaskSettings?
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  userId      String
  workspaceId String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Space {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  name        String
  icon        String    @default("folder")
  iconColor   String    @default("#6472EB")
  description String    @default("")
  archived    Boolean   @default(false)
  archivedAt  DateTime?
  collapsed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Space?    @relation("SpaceChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Space[]   @relation("SpaceChildren")
  pages       Page[]

  @@index([workspaceId])
  @@index([parentId])
}

model Page {
  id          String    @id @default(cuid())
  workspaceId String
  spaceId     String
  title       String
  type        PageType  @default(TEXT)
  content     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  space       Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([workspaceId])
  @@index([spaceId])
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  pageId      String?
  title       String
  description String    @default("")
  status      String
  priority    String
  tag         String
  projectId   String?
  assigneeId  String?
  startDate   DateTime?
  endDate     DateTime?
  color       String?
  notes       String    @default("")
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  createdBy   User      @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignee    User?     @relation("TaskAssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([pageId])
  @@index([assigneeId])
}

model TaskSettings {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  projects    Json
  assignees   Json
  labels      Json
  priorities  Json
  statuses    Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
