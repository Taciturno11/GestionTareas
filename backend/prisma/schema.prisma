generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum SpaceShareRole {
  VIEWER
  EDITOR
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum PageType {
  BLANK
  TEXT
  BOARD
  DATABASE
  TASKS
  TIME_REPORT
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  name                String
  role                String            @default("usuario")
  passwordHash        String
  avatarUrl           String?
  personalWorkspaceId String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  personalWorkspace   Workspace?        @relation("PersonalWorkspace", fields: [personalWorkspaceId], references: [id], onDelete: SetNull)
  memberships         WorkspaceMember[]
  sentFriendRequests  FriendRequest[]   @relation("FriendRequestRequester")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestRecipient")
  friendshipsA        Friendship[]       @relation("FriendshipUserA")
  friendshipsB        Friendship[]       @relation("FriendshipUserB")
  spaceShares         SpaceShare[]      @relation("SpaceShareUser")
  spaceSharesCreated  SpaceShare[]      @relation("SpaceShareCreator")
  tasksCreated        Task[]            @relation("TaskCreatedBy")
  tasksAssigned       Task[]            @relation("TaskAssignedTo")
}

model FriendRequest {
  id          String              @id @default(cuid())
  requesterId String
  recipientId String
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  respondedAt DateTime?
  requester   User                @relation("FriendRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   User                @relation("FriendRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([requesterId, status])
  @@index([recipientId, status])
  @@index([requesterId, recipientId])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId])
}

model Workspace {
  id               String            @id @default(cuid())
  name             String
  color            String            @default("#6472EB")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          WorkspaceMember[]
  spaces           Space[]
  pages            Page[]
  tasks            Task[]
  projects         Project[]
  settings         TaskSettings?
  personalForUsers User[]            @relation("PersonalWorkspace")
}

model Project {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  color       String    @default("#6472EB")
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, name])
  @@unique([id, workspaceId])
  @@index([workspaceId, archivedAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  userId      String
  workspaceId String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Space {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  name        String
  icon        String    @default("folder")
  iconColor   String    @default("#6472EB")
  description String    @default("")
  archived    Boolean   @default(false)
  archivedAt  DateTime?
  collapsed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Space?    @relation("SpaceChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Space[]   @relation("SpaceChildren")
  pages       Page[]
  shares      SpaceShare[]

  @@index([workspaceId])
  @@index([parentId])
}

model SpaceShare {
  id          String         @id @default(cuid())
  spaceId     String
  userId      String
  role        SpaceShareRole @default(VIEWER)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  space       Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user        User           @relation("SpaceShareUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("SpaceShareCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([spaceId, userId])
  @@index([userId])
  @@index([spaceId])
}

model Page {
  id          String    @id @default(cuid())
  workspaceId String
  spaceId     String
  title       String
  type        PageType  @default(TEXT)
  content     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  space       Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([workspaceId])
  @@index([spaceId])
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  pageId      String?
  title       String
  description String    @default("")
  status      String
  priority    String
  tag         String
  projectId   String?
  assigneeId  String?
  startDate   DateTime?
  endDate     DateTime?
  color       String?
  notes       String    @default("")
  position    Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  createdBy   User      @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignee    User?     @relation("TaskAssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, status, position])
  @@index([projectId, workspaceId])
  @@index([pageId])
  @@index([assigneeId])
}

model TaskSettings {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  projects    Json
  assignees   Json
  labels      Json
  priorities  Json
  statuses    Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
